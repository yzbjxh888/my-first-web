<!--
  ========================================================
  日报模板 — 五章，不含系统状态
  ========================================================
  关键规则：
  1. NO inline <style> block — 全部使用外部 styles.css
  2. 侧边栏用相对路径 ../index.html
  3. 每个 section 用 <section class="card"><h2>...</h2> 包裹
  4. 每个条目用 <div class="card-content"> 放在 section 内部
  5. 所有链接带 .html 后缀
  6. 存档链接用绝对路径 /daily/YYYY-MM-DD.html
  7. ⚠️ 不包含系统状态 — 日报只写技术趋势
-->

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YYYY-MM-DD 日报 | Hermes Agent</title>
  <link rel="stylesheet" href="../styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <div class="app-container">
    <aside class="sidebar">
      <div class="sidebar-brand">HERMES</div>
      <nav class="sidebar-nav">
        <a href="../index.html" class="nav-item"><span class="icon">📊</span>仪表板</a>
        <a href="../daily/index.html" class="nav-item active"><span class="icon">📰</span>日报</a>
        <a href="../skills.html" class="nav-item"><span class="icon">🛠️</span>技能</a>
        <a href="../tools.html" class="nav-item"><span class="icon">🔧</span>工具</a>
        <a href="../personal/about.html" class="nav-item"><span class="icon">👤</span>关于</a>
      </nav>
    </aside>
    <main class="main-content">
      <header>
        <h1>YYYY年M月D日 技术日报</h1>
        <p class="subtitle">探索 AI 与开发者生态的最前沿</p>
      </header>

      <!-- ═══════════════════════════════════════
           Section 1: 今日重点 (4-5条)
           ═══════════════════════════════════════ -->
      <section class="card">
        <h2>📌 今日重点</h2>

        <div class="card-content">
          <h3>📰 标题</h3>
          <div class="meta">
            <span class="tag">🏷️ 标签</span>
            <span class="source"><a href="原文链接" target="_blank" rel="noopener noreferrer">🔗 原文</a></span>
          </div>
          <p><strong>一句话总结：</strong>核心变化。</p>
          <p><strong>深度分析：</strong>3-5 句深入分析。</p>
          <p><strong>开发者视角：</strong>这对你意味着什么。</p>
        </div>

        <!-- 更多重点条目... -->
      </section>

      <!-- ═══════════════════════════════════════
           Section 2: 开源动态 (8-12条)
           ═══════════════════════════════════════ -->
      <section class="card">
        <h2>🔥 开源动态</h2>

        <div class="card-content">
          <h3><a href="https://github.com/owner/repo" target="_blank" rel="noopener noreferrer">owner/repo</a> ⭐ 热度</h3>
          <div class="meta"><span class="tag">🏷️ 分类</span></div>
          <p>项目简介和核心亮点。</p>
        </div>

        <!-- 更多开源条目... -->
      </section>

      <!-- ═══════════════════════════════════════
           Section 3: 开发者生态 (8-12条)
           ═══════════════════════════════════════ -->
      <section class="card">
        <h2>🧰 开发者生态</h2>

        <div class="card-content">
          <h3><a href="原文链接" target="_blank" rel="noopener noreferrer">标题</a></h3>
          <div class="meta">
            <span class="tag">🏷️ 标签</span>
            <span class="source">来源: 出处</span>
          </div>
          <p>1-2 句摘要。</p>
        </div>

        <!-- 更多生态条目... -->
      </section>

      <!-- ═══════════════════════════════════════
           Section 4: AI 与 Agent 前沿 (5-8条)
           ═══════════════════════════════════════ -->
      <section class="card">
        <h2>🤖 AI 与 Agent 前沿</h2>

        <div class="card-content">
          <h3>📰 标题</h3>
          <div class="meta">
            <span class="tag">🏷️ 标签</span>
            <span class="source"><a href="原文链接" target="_blank" rel="noopener noreferrer">🔗 详情</a></span>
          </div>
          <p><strong>一句话总结：</strong>核心内容。</p>
          <p><strong>深度分析：</strong>深入分析。</p>
          <p><strong>开发者视角：</strong>对开发者的意义。</p>
        </div>

        <!-- 更多条目... -->
      </section>

      <!-- ═══════════════════════════════════════
           Section 5: 论文推荐 (5-8条)
           ═══════════════════════════════════════ -->
      <section class="card">
        <h2>📚 论文推荐</h2>

        <div class="card-content">
          <h3><a href="https://arxiv.org/abs/xxxx" target="_blank" rel="noopener noreferrer">论文标题</a></h3>
          <div class="meta">
            <span class="tag">🏷️ 领域</span>
            <span class="source">ArXiv · YYYY-MM-DD</span>
          </div>
          <p><strong>核心贡献：</strong>一句话。</p>
          <p><strong>方法：</strong>简述方法。</p>
        </div>

        <!-- 更多论文条目... -->
      </section>

      <footer>
        Generated by Hermes Agent · YYYY-MM-DD
      </footer>
    </main>
  </div>
</body>
</html>